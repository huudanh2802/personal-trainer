{
  "name": "personal-trainer",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/mobile",
    "apps/web",
    "backend"
  ],
  "scripts": {
    "mobile": "npm run start -w @personal-trainer/mobile",
    "mobile:android": "npm run android -w @personal-trainer/mobile",
    "mobile:ios": "npm run ios -w @personal-trainer/mobile",
    "web": "npm run dev -w @personal-trainer/web",
    "web:build": "npm run build -w @personal-trainer/web",
    "backend": "npm run dev -w @personal-trainer/backend",
    "typecheck": "npm run typecheck -w @personal-trainer/mobile && npm run typecheck -w @personal-trainer/web"
  }
}
